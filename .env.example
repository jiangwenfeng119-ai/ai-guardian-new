# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OpenAI-compatible providers (OpenAI / DeepSeek / Qwen / Moonshot / Zhipu / Doubao / SiliconFlow / Azure OpenAI)
# Frontend reads VITE_* variables; UI form values take precedence over env values.
VITE_OPENAI_API_KEY=""
# Examples:
# - DeepSeek: https://api.deepseek.com/v1
# - Qwen(Bailian): https://dashscope.aliyuncs.com/compatible-mode/v1
# - Moonshot(Kimi): https://api.moonshot.cn/v1
# - Zhipu: https://open.bigmodel.cn/api/paas/v4
# - Doubao(Volcengine Ark): https://ark.cn-beijing.volces.com/api/v3
# - SiliconFlow: https://api.siliconflow.cn/v1
# - OpenAI: https://api.openai.com/v1
# - Azure OpenAI: https://{resource-name}.openai.azure.com/openai/deployments/{deployment-name}
VITE_OPENAI_BASE_URL="https://api.deepseek.com/v1"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Local API (node server/api.cjs). Vite proxies /api -> http://127.0.0.1:8787
API_PORT=8787
# If set, all /api/* mutating routes require: Authorization: Bearer <ADMIN_TOKEN>
ADMIN_TOKEN=

# Secret for signing session JWTs (change in production)
JWT_SECRET=
