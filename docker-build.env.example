# Optional: copy lines into .env (next to docker-compose.yml) if Docker Hub / npm time out.
# NODE_IMAGE=docker.m.daocloud.io/library/node:22-alpine
# NPM_REGISTRY=https://registry.npmmirror.com

# --- OpenAI 兼容 Provider（容器运行时）---
# 复制到 .env 后，前端将通过 VITE_* 注入运行时：
# VITE_OPENAI_API_KEY=sk-xxxx
# VITE_OPENAI_BASE_URL=https://api.deepseek.com/v1
# 常见 BASE_URL：
#   DeepSeek: https://api.deepseek.com/v1
#   Qwen(Bailian): https://dashscope.aliyuncs.com/compatible-mode/v1
#   Moonshot(Kimi): https://api.moonshot.cn/v1
#   Zhipu: https://open.bigmodel.cn/api/paas/v4
#   Doubao(Volcengine Ark): https://ark.cn-beijing.volces.com/api/v3
#   SiliconFlow: https://api.siliconflow.cn/v1
#   OpenAI: https://api.openai.com/v1
#   Azure OpenAI: https://{resource-name}.openai.azure.com/openai/deployments/{deployment-name}

# --- Ollama（Docker / 测试环境常见问题）---
# 1) 反代目标：默认 http://host.docker.internal:11434；Ollama 不在本机 11434 时改为实际地址，例如：
# OLLAMA_PROXY_TARGET=http://192.168.1.10:11434
# 2) 宿主机 Ollama 若只监听 127.0.0.1，从容器访问会失败。请让 Ollama 监听 0.0.0.0，例如：
#    export OLLAMA_HOST=0.0.0.0:11434
#    然后重启 ollama serve（或系统服务）。
# 3) 部署后可在浏览器打开：与前端同源的 /api/health/ollama（经 Vite 代理则为 http://localhost:3000/api/health/ollama）
#    返回 ok:true 表示 API 进程能连上 Ollama。
# 4) 反代超时（毫秒，默认 600000）：
# OLLAMA_PROXY_TIMEOUT_MS=600000

# --- 法律法规检索（API 在 Docker、Agent 在本机宿主机时）---
# 后端 POST JSON 仅 { query }，与同机 fetch http://localhost:3001/agent/search 一致。
# URL 优先级：界面/设置中的「完整 URL」> 环境变量 LEGAL_IMA_SEARCH_URL。
# localhost 在容器内会自动解析为 host.docker.internal（compose 已含 extra_hosts 时 Linux 可用）。
# LEGAL_IMA_SEARCH_URL=http://localhost:3001/agent/search
# 可选：强制上游主机名
# LEGAL_IMA_HOST=
# Agent 自检（宿主机）：curl -s http://localhost:3001/health
# 期望含 "service":"IMA Agent API"，主要检索接口为 POST /agent/search（body: {"query":"..."}）
